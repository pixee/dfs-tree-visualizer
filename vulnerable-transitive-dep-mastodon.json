    "vulnerability": {
      "id": "CVE-2026-23745",
      "description": "Arbitrary file overwrite vulnerability in tar. When extracting a crafted tar archive, an attacker can write files outside the intended extraction directory, potentially overwriting critical system or application files.",
      "severity": "HIGH",
      "primary_url": "https://nvd.nist.gov/vuln/detail/CVE-2026-23745",
      "affected_versions": "<=7.4.3"
    },
    "additional_vulnerabilities": [
      {
        "id": "CVE-2026-23950",
        "description": "Symlink poisoning vulnerability in tar. An attacker can craft a tar archive containing symlinks that, when extracted, allow file reads or writes outside the intended directory via symlink traversal.",
        "severity": "HIGH",
        "primary_url": "https://nvd.nist.gov/vuln/detail/CVE-2026-23950"
      },
      {
        "id": "CVE-2026-24842",
        "description": "Path traversal vulnerability in tar. Maliciously crafted tar entries with relative path components (../) can escape the extraction directory, enabling arbitrary file placement on the filesystem.",
        "severity": "HIGH",
        "primary_url": "https://nvd.nist.gov/vuln/detail/CVE-2026-24842"
      },
      {
        "id": "CVE-2026-26960",
        "description": "Additional file overwrite vector in tar via crafted archive entries that bypass path sanitization, allowing arbitrary file writes during extraction.",
        "severity": "HIGH",
        "primary_url": "https://nvd.nist.gov/vuln/detail/CVE-2026-26960"
      }
    ]
