    "vulnerability": {
      "id": "CVE-2026-25765",
      "description": "Server-Side Request Forgery (SSRF) vulnerability in Faraday HTTP client library. An attacker can craft requests that cause the Faraday client to make unintended HTTP requests to internal services, potentially exposing internal network resources, reading metadata endpoints, or pivoting to attack internal infrastructure.",
      "severity": "MEDIUM",
      "cvss_score": 6.5,
      "cvss_vector": "CVSS:3.1/AV:N/AC:L/PR:L/UI:N/S:C/C:L/I:L/A:N",
      "primary_url": "https://nvd.nist.gov/vuln/detail/CVE-2026-25765",
      "affected_versions": ">= 2.0.0, < 2.15.0"
    },
    "selection_rationale": "Faraday was chosen as the most complex dependency because it has 6 distinct upstream paths from direct Gemfile dependencies, crosses multiple functional domains (authentication, API integration, vendor plugins), and its own transitive sub-chain (faraday -> faraday-net_http -> net-http -> uri) links to a SECOND vulnerable dependency (uri@1.1.1, CVE-2025-61594). This creates a rare dual-vulnerability transitive chain within a single dependency subgraph."
  },
  "dependency_chain": {
    "description": "faraday@2.14.1 is BOTH a direct dependency (declared in Gemfile line 257) AND a transitive dependency reached through 5 additional indirect paths. It is pulled in by octokit (GitHub API client), sawyer (GitHub API hypermedia layer), oauth2 (OAuth2 authentication via omniauth), zendesk_api (Zendesk plugin integration), and faraday-retry (retry middleware). Additionally, faraday's own sub-dependency chain faraday -> faraday-net_http -> net-http -> uri connects it to the separately-vulnerable uri@1.1.1 gem (CVE-2025-61594, credential exposure).",
    "path": [
